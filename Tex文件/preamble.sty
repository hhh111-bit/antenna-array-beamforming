% \renewcommand{\section}{\clearpage\oldsection}

% 彩色笔记框
\usepackage[most]{tcolorbox}
\newtcolorbox{infobox}[1]{
  colback=softblue,
  colframe=mainblue,
  title=#1,
  fonttitle=\bfseries,
  breakable,
  arc=2mm
}

